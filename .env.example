# Supabase — Project Settings > API
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # server-only, never ship to client

# App
SESSION_SECRET=generate-a-long-random-string             # python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_BASE_URL=http://localhost:8000                       # no trailing slash; on Render use https://your-app.onrender.com
COOKIE_SECURE=false                                      # true on Render (HTTPS)
DEFAULT_COHORT_TAG=pilot

# Slice 3 — RunPod (the live Slice 0 endpoint)
RUNPOD_ENDPOINT_ID=your-endpoint-id                      # from the endpoint Overview/URL, NOT the display name
RUNPOD_API_KEY=your-runpod-api-key                       # RunPod > Settings > API Keys
MODEL_VERSION=whisperx-large-v3-baseline                 # stamped on usage_events; bump when you swap the fine-tune
MONTHLY_QUOTA_SECONDS=36000                              # soft cap per cycle (10h)
